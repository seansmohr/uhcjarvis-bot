# ── Jarvis credentials ─────────────────────────────────────────────────────
JARVIS_USERNAME=your_username_or_email
JARVIS_PASSWORD=your_password

# ── Session (output from seed_session.py — treat like a password) ──────────
JARVIS_SESSION_B64=

# ── Email delivery ─────────────────────────────────────────────────────────
# Gmail: create an App Password at myaccount.google.com/apppasswords
# (requires 2-Step Verification to be enabled on your Google account)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=you@gmail.com
SMTP_PASSWORD=your_gmail_app_password
EMAIL_TO=recipient@example.com

# ── Trigger protection ─────────────────────────────────────────────────────
# Set to any random string. Required in the URL: POST /run?token=<value>
TRIGGER_TOKEN=change_me_to_a_random_secret
